{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "strict": false,
    "skipLibCheck": true,
    "types": ["node", "@playwright/test"],
    "outDir": "dist"
  },
  "include": [
    "scripts/**/*.ts",
    "generated-tests/**/*.ts",
    "playwright.config.ts"
  ]
}
